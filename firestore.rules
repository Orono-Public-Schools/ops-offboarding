rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@orono[.]k12[.]mn[.]us');
    }

    function isSelf(offboardingId) {
      return isAuthed() && request.auth.uid == offboardingId;
    }

    function isItAdmin() {
      return isAuthed() && request.auth.token.it_admin == true;
    }

    // Offboarding records. Document ID == user's Firebase UID, so rules
    // authorize by path — which also lets the client distinguish
    // "doesn't exist yet" from "denied" for first-time users.
    // All writes go through Cloud Functions for validation + audit.
    match /offboardings/{offboardingId} {
      allow read: if isSelf(offboardingId) || isItAdmin();
      allow write: if false;

      match /fileScan/{fileId} {
        allow read: if isSelf(offboardingId) || isItAdmin();
        allow write: if false;
      }

      match /auditLog/{logId} {
        allow read: if isSelf(offboardingId) || isItAdmin();
        allow write: if false;
      }
    }

    // Successor lookup cache — any authed domain user can read.
    match /successors/{email} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // Staff roster synced from a spreadsheet via syncStaffRoster.
    // Any authed domain user can read for the person picker; writes are
    // server-side only.
    match /staff/{email} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // App-wide settings IT admins can edit (e.g. EOY return date).
    // Authed users read so the SummerVacationResponderTask can pick up
    // the configured date; writes go through callables.
    match /appSettings/{key} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
